---
layout: layouts/base.njk
title: Dump Viewer
permalink: /dump/
description: "Inspect CommandBridge support dumps — servers, scripts, config, and diagnostics."
hideFooter: true
---

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css" media="(prefers-color-scheme: dark)"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css" media="(prefers-color-scheme: light)"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/cytoscape/3.28.1/cytoscape.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/js-yaml/4.1.0/js-yaml.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/yaml.min.js"></script>

<div x-data="dumpViewer()" x-init="init()" class="dv-root">

  {# ── Error overlay ── #}
  <div x-show="error" x-cloak class="dv-overlay dv-overlay-err">
    <span x-text="error"></span>
    <button class="dv-link" @click="error = ''">dismiss</button>
  </div>

  {# ══════════ LEFT COLUMN ══════════ #}
  <aside class="dv-col dv-left">

    {# ── Servers ── #}
    <div class="dv-panel">
      <div class="dv-panel-head">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
        <span>Servers</span>
        <span class="dv-panel-count" x-show="hasDump" x-text="servers().length" x-cloak></span>
      </div>
      <div class="dv-list" x-show="hasDump">
        <template x-for="(srv, i) in servers()" :key="i">
          <button class="dv-item" :class="isActive('server', i) && 'dv-item-active'" @click="openServer(i)">
            <span class="dv-dot" :class="srv.connected ? 'dv-dot-on' : 'dv-dot-off'"></span>
            <span class="dv-item-name" x-text="srv.label"></span>
            <span class="dv-item-tag" x-text="srv.location"></span>
          </button>
        </template>
      </div>
      <div class="dv-sidebar-empty" x-show="!hasDump" x-cloak>
        <p>No servers loaded</p>
      </div>
      <div class="dv-sidebar-empty" x-show="hasDump && servers().length === 0" x-cloak>
        <p>No servers in dump</p>
      </div>
    </div>

    {# ── Scripts ── #}
    <div class="dv-panel dv-panel-grow">
      <div class="dv-panel-head">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        <span>Scripts</span>
        <span class="dv-panel-count" x-show="hasDump" x-text="scriptsList().length" x-cloak></span>
      </div>
      <div class="dv-list" x-show="hasDump">
        <template x-for="(s, i) in scriptsList()" :key="i">
          <button class="dv-item" :class="isActive('script', i) && 'dv-item-active'" @click="openScript(i)">
            <span class="dv-dot" :class="s.enabled ? 'dv-dot-on' : 'dv-dot-off'"></span>
            <span class="dv-item-name" x-text="scriptName(s, i)"></span>
          </button>
        </template>
      </div>
      <div class="dv-sidebar-empty" x-show="!hasDump" x-cloak>
        <p>No scripts available</p>
      </div>
      <div class="dv-sidebar-empty" x-show="hasDump && scriptsList().length === 0" x-cloak>
        <p>No scripts in dump</p>
      </div>
    </div>
  </aside>

  {# ══════════ CENTER COLUMN ══════════ #}
  <main class="dv-col dv-center">

    {# ── Loading (inline) ── #}
    <div class="dv-center-empty" x-show="loading" x-cloak>
      <span class="dv-spinner dv-spinner-lg"></span>
      <p>Loading dump...</p>
    </div>

    {# ── No dump loaded ── #}
    <div class="dv-landing" x-show="!hasDump && !loading" x-cloak>
      <div class="dv-landing-inner">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="dv-landing-icon"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <h2 class="dv-landing-title">Dump Viewer</h2>
        <p class="dv-landing-desc">View and inspect CommandBridge support dumps.</p>
        <div class="dv-landing-input-wrap">
          <label class="dv-landing-label" for="dv-id-input">Dump ID</label>
          <div class="dv-landing-row">
            <input id="dv-id-input" type="text" class="dv-landing-input" placeholder="Paste a dump ID..." x-model="queryId" @keydown.enter="loadDump(queryId)"/>
            <button class="dv-landing-btn" @click="loadDump(queryId)" :disabled="!queryId.trim()">Load</button>
          </div>
        </div>
        <div class="dv-landing-hint">
          <p>Run <code>/cb dump</code> in-game to generate a dump, then paste the ID above.</p>
          <p>Or open <code>/dump/?id=&lt;id&gt;</code> directly.</p>
        </div>
      </div>
    </div>

    {# ── No selection (dump loaded) ── #}
    <div class="dv-center-empty" x-show="hasDump && !view" x-cloak>
      <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="dv-center-icon"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
      <p>Select a server or script</p>
      <p class="dv-muted">Choose an item from the left sidebar</p>
    </div>

    {# ── Script detail ── #}
    <div x-show="view === 'script'" x-cloak class="dv-detail">
      <div class="dv-detail-head">
        <h2 class="dv-detail-title" x-text="detailTitle"></h2>
        <span class="dv-dot dv-dot-inline" :class="activeScript()?.enabled ? 'dv-dot-on' : 'dv-dot-off'"></span>
        <span class="dv-detail-subtitle" x-text="activeScript()?.enabled ? 'Enabled' : 'Disabled'"></span>
        <button class="dv-link dv-ml-auto" @click="copyYaml(activeScript())">copy yaml</button>
      </div>

      <template x-if="activeScript()">
        <div>
          <div class="dv-card">
            <div class="dv-card-head">Script</div>
            <pre class="dv-pre"><code class="language-yaml" x-html="highlightScriptYaml(activeScript())"></code></pre>
          </div>

          {# Per-script graph #}
          <template x-if="scriptGraphData()">
            <div class="dv-card">
              <div class="dv-card-head">Execution Map</div>
              <div :id="'cy-script-' + activeScriptIndex" class="dv-cy" x-init="$nextTick(() => renderScriptGraph())"></div>
            </div>
          </template>
        </div>
      </template>
    </div>

    {# ── Server detail ── #}
    <div x-show="view === 'server'" x-cloak class="dv-detail">
      <div class="dv-detail-head">
        <h2 class="dv-detail-title" x-text="detailTitle"></h2>
        <span class="dv-dot dv-dot-inline" :class="activeServerData()?.connected ? 'dv-dot-on' : 'dv-dot-off'"></span>
        <span class="dv-detail-subtitle" x-text="activeServerData()?.isProxy ? 'Proxy' : (activeServerData()?.connected ? 'Connected' : 'Disconnected')"></span>
      </div>

      {# Velocity proxy view #}
      <template x-if="activeServerData() && activeServerData().isProxy">
        <div>
          <div class="dv-card">
            <div class="dv-card-head">Server Information</div>
            <dl class="dv-dl">
              <dt>Platform</dt>
              <dd x-text="pluginMetric('platform')"></dd>
              <dt>Plugin</dt>
              <dd><span x-text="pluginMetric('name')"></span> <span class="dv-muted" x-text="pluginMetric('version')"></span></dd>
              <dt>Java</dt>
              <dd x-text="runtimeMetric('javaVersion')"></dd>
              <dt>OS</dt>
              <dd><span x-text="runtimeMetric('os')"></span> <span class="dv-muted" x-text="runtimeMetric('osArch')"></span></dd>
              <dt>Uptime</dt>
              <dd x-text="formatDuration(runtimeMetric('uptimeMs'))"></dd>
              <dt>Memory</dt>
              <dd x-text="memoryLabel()"></dd>
              <dt>Clients</dt>
              <dd x-text="summaryMetric('totalClients') + ' total, ' + summaryMetric('connectedClients') + ' connected'"></dd>
            </dl>
          </div>

          <div class="dv-card">
            <div class="dv-card-head">Configuration</div>
            <pre class="dv-pre"><code class="language-yaml" x-html="highlightYaml(dv('config', {}))"></code></pre>
          </div>
        </div>
      </template>

      {# Backend server view #}
      <template x-if="activeServerData() && !activeServerData().isProxy">
        <div>
          <div class="dv-card">
            <div class="dv-card-head">Session</div>
            <dl class="dv-dl">
              <dt>ID</dt>
              <dd><code x-text="activeServerData().id"></code></dd>
              <dt>Location</dt>
              <dd x-text="activeServerData().location"></dd>
              <dt>Status</dt>
              <dd><span class="dv-status-badge" :class="statusClass(activeServerData().status)" x-text="activeServerData().status"></span></dd>
              <dt>Endpoint</dt>
              <dd><code class="dv-code-sm" x-text="safe(activeServerData().endpoint)"></code></dd>
              <dt>Targeted Scripts</dt>
              <dd x-text="safe(activeServerData().targetedScriptCount, 0)"></dd>
            </dl>
          </div>

          {# Remote snapshot #}
          <template x-if="activeServerRemote()">
            <div>
              <template x-if="activeServerRemote().snapshot && activeServerRemote().snapshot.runtime">
                <div class="dv-card">
                  <div class="dv-card-head">Remote Snapshot</div>
                  <dl class="dv-dl">
                    <dt>Platform</dt>
                    <dd x-text="safe(activeServerRemote().snapshot.runtime.platform)"></dd>
                    <dt>Java</dt>
                    <dd x-text="safe(activeServerRemote().snapshot.runtime.javaVersion)"></dd>
                    <dt>OS</dt>
                    <dd><span x-text="safe(activeServerRemote().snapshot.runtime.os)"></span> <span class="dv-muted" x-text="safe(activeServerRemote().snapshot.runtime.osArch)"></span></dd>
                    <dt>Uptime</dt>
                    <dd x-text="formatDuration(activeServerRemote().snapshot.runtime.uptimeMs)"></dd>
                    <dt>Players</dt>
                    <dd x-text="safe(activeServerRemote().snapshot.runtime.playerCount, 0)"></dd>
                  </dl>
                </div>
              </template>
              <template x-if="!activeServerRemote().collected">
                <div class="dv-card">
                  <div class="dv-card-head">Remote Snapshot</div>
                  <p class="dv-muted" style="padding:12px 14px;font-size:12px">Collection failed: <span class="text-destructive" x-text="safe(activeServerRemote().reason, 'unknown')"></span></p>
                </div>
              </template>

              {# Client config #}
              <template x-if="activeServerRemote().snapshot && activeServerRemote().snapshot.config">
                <div class="dv-card">
                  <div class="dv-card-head">Configuration</div>
                  <pre class="dv-pre"><code class="language-yaml" x-html="highlightYaml(activeServerRemote().snapshot.config)"></code></pre>
                </div>
              </template>

              {# Registered commands #}
              <template x-if="activeServerRemote().snapshot && activeServerRemote().snapshot.registeredCommands && activeServerRemote().snapshot.registeredCommands.length">
                <div class="dv-card">
                  <div class="dv-card-head">Registered Commands <span class="dv-card-count" x-text="activeServerRemote().snapshot.registeredCommands.length"></span></div>
                  <div class="dv-tags" style="padding:12px 14px">
                    <template x-for="cmd in activeServerRemote().snapshot.registeredCommands" :key="cmd">
                      <code class="dv-tag" x-text="cmd"></code>
                    </template>
                  </div>
                </div>
              </template>
            </div>
          </template>

          {# Server connection graph #}
          <template x-if="serverGraphData()">
            <div class="dv-card">
              <div class="dv-card-head">Connection Map</div>
              <div :id="'cy-server-' + activeServerIndex" class="dv-cy" x-init="$nextTick(() => renderServerGraph())"></div>
            </div>
          </template>
        </div>
      </template>
    </div>
  </main>

  {# ══════════ RIGHT COLUMN ══════════ #}
  <aside class="dv-col dv-right">
    <div class="dv-panel dv-panel-grow">
      <div class="dv-panel-head">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        <span>General</span>
      </div>
      <div x-show="hasDump" class="dv-meta">
        <dl class="dv-dl-meta">
          <dt>Dump ID</dt>
          <dd><code class="dv-code-sm" x-text="dumpId"></code></dd>

          <dt>Plugin</dt>
          <dd>
            <span x-text="pluginMetric('name')"></span>
            <span class="dv-muted" x-text="pluginMetric('version')"></span>
          </dd>

          <dt>Platform</dt>
          <dd x-text="pluginMetric('platform')"></dd>

          <dt>Java</dt>
          <dd x-text="runtimeMetric('javaVersion')"></dd>

          <dt>OS</dt>
          <dd>
            <span x-text="runtimeMetric('os')"></span>
            <span class="dv-muted" x-text="runtimeMetric('osArch')"></span>
          </dd>

          <dt>Uptime</dt>
          <dd x-text="formatDuration(runtimeMetric('uptimeMs'))"></dd>

          <dt>Memory</dt>
          <dd x-text="memoryLabel()"></dd>

          <dt>Created</dt>
          <dd x-text="formatTime(envelopeValue('createdAt'))"></dd>

          <dt>Expires</dt>
          <dd x-text="formatTime(envelopeValue('expiresAt'))"></dd>
        </dl>
        <div class="dv-meta-actions">
          <button class="dv-link" @click="copyViewerUrl()">copy link</button>
          <a class="dv-link" :href="rawApiUrl()" target="_blank">raw json</a>
        </div>
      </div>
      <div class="dv-sidebar-empty" x-show="!hasDump" x-cloak>
        <p>No dump loaded</p>
      </div>
    </div>
  </aside>
</div>

<script>
const DUMP_API = "https://cb.objz.dev/api/dump";

function dumpViewer() {
  return {
    queryId: "",
    dumpId: "",
    loading: false,
    error: "",
    hasDump: false,
    envelope: null,
    dump: null,

    view: "",
    viewKey: null,
    detailTitle: "",

    activeScriptIndex: -1,
    activeServerIndex: -1,

    cyInstances: {},

    init() {
      const id = this.extractId();
      if (id) this.loadDump(id);
    },

    extractId() {
      const params = new URLSearchParams(window.location.search);
      const q = (params.get("id") || "").trim();
      if (q) return q;
      const parts = window.location.pathname.replace(/\/+$/, "").split("/").filter(Boolean);
      if (parts.length === 2 && parts[0] === "dump") return parts[1];
      return "";
    },

    async loadDump(id) {
      if (!id || typeof id !== "string") return;
      id = id.trim();
      if (!/^[a-zA-Z0-9_-]{8,64}$/.test(id)) {
        this.error = "Invalid dump ID.";
        return;
      }
      this.loading = true;
      this.error = "";
      this.hasDump = false;
      this.view = "";
      try {
        const res = await fetch(`${DUMP_API}/${encodeURIComponent(id)}`, { headers: { Accept: "application/json" } });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(body?.error || `HTTP ${res.status}`);
        this.dumpId = id;
        this.envelope = body;
        this.dump = body.data || {};
        this.hasDump = true;
        try {
          const url = new URL(window.location.href);
          url.search = `?id=${encodeURIComponent(id)}`;
          window.history.replaceState({}, "", url.toString());
        } catch {}
      } catch (e) {
        this.error = e?.message || "Failed to load dump.";
      } finally {
        this.loading = false;
      }
    },

    /* ── Navigation ── */

    isActive(type, key) {
      return this.view === type && this.viewKey === key;
    },

    openScript(i) {
      this.view = "script";
      this.viewKey = i;
      this.activeScriptIndex = i;
      this.detailTitle = this.scriptName(this.scriptsList()[i], i);
      this.$nextTick(() => this.renderScriptGraph());
    },

    openServer(i) {
      this.view = "server";
      this.viewKey = i;
      this.activeServerIndex = i;
      const srv = this.servers()[i];
      this.detailTitle = srv ? srv.label : "Server";
      this.$nextTick(() => this.renderServerGraph());
    },

    /* ── Data helpers ── */

    dv(key, fb) { return this.dump?.[key] ?? fb; },
    summaryMetric(key) { return this.dv("network", {}).summary?.[key] ?? 0; },
    scriptsMetric(key) { return this.dv("scripts", {})[key] ?? 0; },
    registrationMetric(key) { return this.dv("registrations", {})[key] ?? "-"; },
    pluginMetric(key) { return this.dv("plugin", {})[key] ?? "-"; },
    runtimeMetric(key) { return this.dv("runtime", {})[key] ?? "-"; },
    envelopeValue(key) { return this.envelope?.[key] ?? "-"; },

    servers() {
      const proxy = {
        id: this.registrationMetric("localServerId") || "velocity",
        label: this.registrationMetric("localServerId") || "Velocity",
        location: "VELOCITY",
        connected: true,
        status: "PROXY",
        isProxy: true
      };

      const clients = this.dv("network", {}).clients;
      const backends = Array.isArray(clients) ? clients.map(c => ({
        ...c,
        label: c.id || c.location || "unknown",
        isProxy: false
      })) : [];

      return [proxy, ...backends];
    },

    scriptsList() {
      const list = this.dv("scripts", {}).entries;
      return Array.isArray(list) ? list.filter(x => x && typeof x === "object") : [];
    },

    activeScript() {
      const list = this.scriptsList();
      if (this.activeScriptIndex < 0 || this.activeScriptIndex >= list.length) return null;
      return list[this.activeScriptIndex];
    },

    activeServerData() {
      const list = this.servers();
      if (this.activeServerIndex < 0 || this.activeServerIndex >= list.length) return null;
      return list[this.activeServerIndex];
    },

    activeServerRemote() {
      const srv = this.activeServerData();
      if (!srv || srv.isProxy) return null;
      const entries = this.dv("remoteClients", {}).entries;
      if (!Array.isArray(entries)) return null;
      return entries.find(e => e.id === srv.id) || null;
    },

    scriptName(s, i) {
      if (!s) return `script-${i + 1}`;
      return s.name || s.id || `script-${i + 1}`;
    },

    statusClass(status) {
      if (status === "AUTH_OK") return "dv-status-ok";
      if (status === "AUTH_FAIL" || status === "UNKNOWN") return "dv-status-err";
      return "dv-status-warn";
    },

    safe(v, fb = "-") { return v == null || v === "" ? fb : v; },

    /* ── Deep equality (used by highlightScriptYaml) ── */

    deepEqual(a, b) {
      if (a === b) return true;
      if (a == null && b == null) return true;
      if (a == null || b == null) return false;
      if (typeof a !== typeof b) return false;
      if (typeof a !== "object") return String(a) === String(b);
      if (Array.isArray(a) !== Array.isArray(b)) return false;
      if (Array.isArray(a)) {
        if (a.length !== b.length) return false;
        for (let i = 0; i < a.length; i++) {
          if (!this.deepEqual(a[i], b[i])) return false;
        }
        return true;
      }
      const ka = Object.keys(a), kb = Object.keys(b);
      if (ka.length !== kb.length) return false;
      for (const k of ka) {
        if (!this.deepEqual(a[k], b[k])) return false;
      }
      return true;
    },

    /* ── Formatting ── */

    formatTime(v) {
      if (!v || v === "-") return "-";
      const d = new Date(v);
      return isNaN(d.getTime()) ? String(v) : d.toLocaleString();
    },

    formatDuration(ms) {
      const v = Number(ms);
      if (!Number.isFinite(v) || v < 0) return "-";
      const s = Math.floor(v / 1000);
      const h = Math.floor(s / 3600);
      const m = Math.floor((s % 3600) / 60);
      const r = s % 60;
      if (h > 0) return `${h}h ${m}m ${r}s`;
      if (m > 0) return `${m}m ${r}s`;
      return `${r}s`;
    },

    formatBytes(b) {
      const v = Number(b);
      if (!Number.isFinite(v) || v < 0) return "-";
      if (v < 1024) return `${v} B`;
      if (v < 1048576) return `${(v / 1024).toFixed(1)} KB`;
      return `${(v / 1048576).toFixed(1)} MB`;
    },

    memoryLabel() {
      const m = this.runtimeMetric("memory");
      if (!m || typeof m !== "object") return "-";
      const used = this.formatBytes(m.usedBytes || 0);
      const max = m.maxBytes ? this.formatBytes(m.maxBytes) : null;
      return max ? `${used} / ${max}` : used;
    },

    /* ── YAML / highlighting ── */

    toYaml(v) {
      try {
        if (typeof jsyaml !== "undefined") return jsyaml.dump(v, { indent: 2, lineWidth: 120, noRefs: true });
      } catch {}
      try { return JSON.stringify(v, null, 2); } catch { return String(v); }
    },

    highlightYaml(v) {
      const yaml = this.toYaml(v);
      try {
        if (typeof hljs !== "undefined") return hljs.highlight(yaml, { language: "yaml" }).value;
      } catch {}
      return this.esc(yaml);
    },

    /* Build YAML for a script with inherited command fields grayed out */
    highlightScriptYaml(script) {
      if (!script) return "";
      const yaml = this.toYaml(script);
      const lines = yaml.split("\n");
      const defaults = script.defaults || {};
      const mergeFields = ["runAs", "execute", "server", "delay", "cooldown"];

      /* Find each command entry in commands array and check its fields */
      let inCommands = false;
      let commandIndent = -1;
      let listItemIndent = -1;  /* indent of "- " for command array entries */
      let entryIndent = -1;     /* indent of fields within a command entry */
      let currentCmd = -1;
      let currentField = null;
      let currentFieldIndent = -1;
      const inheritedLines = new Set();

      for (let i = 0; i < lines.length; i++) {
        const line = lines[i];
        const trimmed = line.trimStart();
        const indent = line.length - trimmed.length;

        /* Detect "commands:" top-level key */
        if (/^commands:/.test(trimmed) && indent === 0) {
          inCommands = true;
          commandIndent = indent;
          listItemIndent = commandIndent + 2; /* "- " entries are 2 deeper */
          currentCmd = -1;
          currentField = null;
          continue;
        }

        /* Left another top-level key */
        if (inCommands && indent === 0 && trimmed && !trimmed.startsWith("-") && !trimmed.startsWith("#")) {
          inCommands = false;
          currentField = null;
          continue;
        }

        if (!inCommands) continue;

        /* Detect command array entry "- command: ..." — only at the expected list indent */
        if (trimmed.startsWith("- ") && indent === listItemIndent) {
          currentCmd++;
          entryIndent = indent + 2;
          currentField = null;

          /* The "- command: xxx" line itself is the template — never gray */
          continue;
        }

        if (currentCmd < 0 || !script.commands || currentCmd >= script.commands.length) continue;
        const cmd = script.commands[currentCmd];

        /* Detect a field key at entry indent level */
        const fieldMatch = trimmed.match(/^([a-zA-Z][a-zA-Z0-9]*)\s*:/);
        if (fieldMatch && indent === entryIndent) {
          currentField = fieldMatch[1];
          currentFieldIndent = indent;

          if (mergeFields.includes(currentField) && this.deepEqual(cmd[currentField], defaults[currentField])) {
            inheritedLines.add(i);
          } else {
            currentField = null;
          }
          continue;
        }

        /* If we're inside an inherited field's nested lines, mark those too */
        if (currentField && indent > currentFieldIndent) {
          inheritedLines.add(i);
          continue;
        }

        /* Moved out of the nested block */
        if (currentField && indent <= currentFieldIndent) {
          currentField = null;
          /* Re-check this line as a new field */
          const fm2 = trimmed.match(/^([a-zA-Z][a-zA-Z0-9]*)\s*:/);
          if (fm2 && indent === entryIndent && mergeFields.includes(fm2[1]) && this.deepEqual(cmd[fm2[1]], defaults[fm2[1]])) {
            currentField = fm2[1];
            currentFieldIndent = indent;
            inheritedLines.add(i);
          }
        }
      }

      /* Highlight then wrap inherited lines */
      let highlighted;
      try {
        highlighted = (typeof hljs !== "undefined") ? hljs.highlight(yaml, { language: "yaml" }).value : this.esc(yaml);
      } catch { highlighted = this.esc(yaml); }

      if (inheritedLines.size === 0) return highlighted;

      const hLines = highlighted.split("\n");
      /* Map highlighted lines back — hljs can split spans across lines but line count stays same */
      for (const li of inheritedLines) {
        if (li < hLines.length) {
          hLines[li] = `<span class="dv-yaml-inherited">${hLines[li]}</span>`;
        }
      }
      return hLines.join("\n");
    },

    esc(s) {
      return String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    },

    /* ── Clipboard ── */

    rawApiUrl() { return this.dumpId ? `${DUMP_API}/${encodeURIComponent(this.dumpId)}` : DUMP_API; },
    async copyViewerUrl() { await this.clip(`https://cb.objz.dev/dump/?id=${encodeURIComponent(this.dumpId)}`); },
    async copyYaml(v) { await this.clip(this.toYaml(v)); },
    async clip(t) { try { await navigator.clipboard.writeText(t); } catch { this.error = "Clipboard failed."; } },

    /* ── Cytoscape: per-script graph ── */

    scriptGraphData() {
      const s = this.activeScript();
      if (!s) return null;
      const topo = this.dv("topology", null);
      if (!topo?.nodes?.length) return null;
      const sName = s.name || s.id;
      const scriptNode = topo.nodes.find(n => n.kind === "SCRIPT" && (n.label === sName || n.id === sName));
      if (!scriptNode) return null;
      const edges = topo.edges.filter(e => e.from === scriptNode.id || e.to === scriptNode.id);
      const nodeIds = new Set([scriptNode.id]);
      edges.forEach(e => { nodeIds.add(e.from); nodeIds.add(e.to); });
      const extraEdges = topo.edges.filter(e => nodeIds.has(e.from) && nodeIds.has(e.to));
      const nodes = topo.nodes.filter(n => nodeIds.has(n.id));
      return { nodes, edges: extraEdges };
    },

    renderScriptGraph() {
      const data = this.scriptGraphData();
      const id = `cy-script-${this.activeScriptIndex}`;
      const el = document.getElementById(id);
      if (!el || !data) return;
      this.renderCy(el, data);
    },

    /* ── Cytoscape: per-server graph ── */

    serverGraphData() {
      const srv = this.activeServerData();
      if (!srv || srv.isProxy) return null;
      const topo = this.dv("topology", null);
      if (!topo?.nodes?.length) return null;
      const sessionNode = topo.nodes.find(n => n.kind === "SESSION" && (n.id === srv.id || n.label === srv.id));
      if (!sessionNode) return null;
      const nodeIds = new Set([sessionNode.id]);
      let changed = true;
      while (changed) {
        changed = false;
        for (const e of topo.edges) {
          if (nodeIds.has(e.to) && !nodeIds.has(e.from)) { nodeIds.add(e.from); changed = true; }
          if (nodeIds.has(e.from) && !nodeIds.has(e.to)) { nodeIds.add(e.to); changed = true; }
        }
      }
      const nodes = topo.nodes.filter(n => nodeIds.has(n.id));
      const edges = topo.edges.filter(e => nodeIds.has(e.from) && nodeIds.has(e.to));
      return { nodes, edges };
    },

    renderServerGraph() {
      const data = this.serverGraphData();
      const id = `cy-server-${this.activeServerIndex}`;
      const el = document.getElementById(id);
      if (!el || !data) return;
      this.renderCy(el, data);
    },

    /* ── Shared Cytoscape renderer ── */

    renderCy(container, data) {
      const prev = this.cyInstances[container.id];
      if (prev) { prev.destroy(); delete this.cyInstances[container.id]; }

      const isDark = document.documentElement.classList.contains("dark");

      const kindColors = {
        VELOCITY_LOCAL: "#3b82f6",
        SCRIPT: "#8b5cf6",
        TARGET: "#06b6d4",
        SESSION: "#10b981"
      };
      const kindShapes = {
        VELOCITY_LOCAL: "round-rectangle",
        SCRIPT: "diamond",
        TARGET: "round-rectangle",
        SESSION: "ellipse"
      };

      const elements = [];
      for (const n of data.nodes) {
        let color = kindColors[n.kind] || "#6b7280";
        if ((n.kind === "TARGET" || n.kind === "SESSION") && n.connected === false) color = "#ef4444";
        const shape = kindShapes[n.kind] || "ellipse";
        elements.push({ group: "nodes", data: { id: n.id, label: n.label || n.id, kind: n.kind, color, shape } });
      }
      for (const e of data.edges) {
        elements.push({ group: "edges", data: { source: e.from, target: e.to, type: e.type } });
      }

      const edgeColor = isDark ? "rgba(148,163,184,0.35)" : "rgba(100,116,139,0.35)";
      const textColor = isDark ? "#e2e8f0" : "#1e293b";

      const cy = cytoscape({
        container,
        elements,
        style: [
          { selector: "node", style: {
            "background-color": "data(color)",
            "background-opacity": 0.15,
            "border-width": 2,
            "border-color": "data(color)",
            shape: "data(shape)",
            label: "data(label)",
            "font-size": "11px",
            "font-family": "Inter, system-ui, sans-serif",
            "font-weight": 500,
            color: textColor,
            "text-valign": "center",
            "text-halign": "center",
            width: "label",
            height: 32,
            "padding": "12px",
            "text-wrap": "none"
          }},
          { selector: 'node[kind="VELOCITY_LOCAL"]', style: {
            "font-weight": 600,
            "font-size": "12px",
            "border-width": 2.5
          }},
          { selector: 'node[kind="SCRIPT"]', style: {
            height: 36,
            "padding": "16px"
          }},
          { selector: "edge", style: {
            "line-color": edgeColor,
            "target-arrow-color": edgeColor,
            "target-arrow-shape": "triangle",
            "curve-style": "bezier",
            width: 1.5,
            "arrow-scale": 0.7,
            opacity: 0.8
          }}
        ],
        layout: {
          name: "concentric",
          concentric: function(node) {
            const k = node.data("kind");
            if (k === "VELOCITY_LOCAL") return 4;
            if (k === "SCRIPT") return 3;
            if (k === "TARGET") return 2;
            if (k === "SESSION") return 1;
            return 0;
          },
          levelWidth: function() { return 1; },
          spacingFactor: 1.6,
          padding: 30,
          minNodeSpacing: 40,
          avoidOverlap: true,
          animate: false
        },
        userZoomingEnabled: true,
        userPanningEnabled: true,
        boxSelectionEnabled: false,
        minZoom: 0.4,
        maxZoom: 3
      });

      cy.on("layoutstop", () => { cy.fit(undefined, 30); });
      this.cyInstances[container.id] = cy;
    }
  };
}
</script>

