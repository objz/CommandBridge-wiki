<style>
  @keyframes glint-right {
    0%,100% { transform: translateX(0);   opacity: .6; }
    50%      { transform: translateX(6px); opacity: 1;  }
  }
  @keyframes glint-left {
    0%,100% { transform: translateX(0);     opacity: .6; }
    50%      { transform: translateX(-6px);  opacity: 1;  }
  }
  @keyframes pulse-dot {
    0%,100% { opacity: .3; }
    50%     { opacity: 1;  }
  }

  .arrow-svg {
    width: 8rem;
    height: 1.5rem;
    stroke: currentColor;
    stroke-width: 2;
    fill: none;
    opacity: .6;
    transform-origin: center;
  }
  .arrow-right { animation: glint-right 1.2s ease-in-out infinite; }
  .arrow-left  { animation: glint-left  1.2s ease-in-out infinite; }

  .arrow-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .cb-bg {
    filter: blur(1.5px);
    -webkit-filter: blur(1.5px);
  }

  .stat-number {
    font-variant-numeric: tabular-nums;
  }

  /* ── Graph nodes ── */
  .net-node {
    padding: 0.5rem 0.6rem;
    border-radius: 0.75rem;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card));
    text-align: center;
  }

  .net-node-hub {
    border-color: rgba(99, 102, 241, 0.45);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.06);
  }

  .net-node h4 {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .net-node .net-sub {
    margin: 0.05rem 0 0;
    font-size: 0.62rem;
    line-height: 1.3;
    color: hsl(var(--muted-foreground));
  }

  .net-icon {
    width: 1.3rem;
    height: 1.3rem;
    margin: 0 auto 0.15rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .net-icon-blue   { background: rgba(59,130,246,0.14); color: #60a5fa; }
  .net-icon-indigo { background: rgba(99,102,241,0.17); color: #a5b4fc; }
  .net-icon-green  { background: rgba(16,185,129,0.14); color: #6ee7b7; }

  /* ── Connection lines ── */
  .net-h-line {
    height: 2px;
    background: hsl(var(--border));
    position: relative;
    flex: 1;
    min-width: 1.5rem;
  }

  .net-h-line::after {
    content: '';
    position: absolute;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #7dd3fc;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  .net-v-line {
    width: 2px;
    height: 0.6rem;
    background: hsl(var(--border));
    margin: 0 auto;
    position: relative;
  }

  .net-v-line::after {
    content: '';
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: #7dd3fc;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  .net-pd1::after { animation-delay: .25s; }
  .net-pd2::after { animation-delay: .5s;  }
  .net-pd3::after { animation-delay: .75s; }
  .net-pd4::after { animation-delay: 1s;   }
  .net-pd5::after { animation-delay: 1.25s;}

  @media (max-width: 640px) {
    .hero-graph-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      margin: 0 -1rem;
      padding: 0 1rem;
    }
    .hero-graph-inner {
      min-width: 480px;
    }
  }
</style>
