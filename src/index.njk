{# ── Three.js background ── #}
<script type="module">
  import * as THREE from 'https://cdn.skypack.dev/three@0.152.2';

  const bgCanvas = document.getElementById('cb-background');
  const bgRenderer = new THREE.WebGLRenderer({ canvas: bgCanvas, alpha: true });
  const bgScene = new THREE.Scene();
  const bgCamera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
  bgCamera.position.z = 2.5;

  const geometry = new THREE.IcosahedronGeometry(1.2, 2);
  const material = new THREE.MeshStandardMaterial({ color: 0xffffff, emissive: 0x000000, wireframe: true });
  const voidMesh = new THREE.Mesh(geometry, material);
  bgScene.add(voidMesh);

  const pointLight = new THREE.PointLight(0xffffff, 1);
  pointLight.position.set(5, 5, 5);
  bgScene.add(pointLight);

  function animateBg() {
    requestAnimationFrame(animateBg);
    voidMesh.rotation.x += 0.002;
    voidMesh.rotation.y += 0.004;
    bgRenderer.setSize(bgCanvas.clientWidth, bgCanvas.clientHeight, false);
    bgRenderer.render(bgScene, bgCamera);
  }
  animateBg();

  window.addEventListener('resize', () => {
    bgCamera.aspect = window.innerWidth / window.innerHeight;
    bgCamera.updateProjectionMatrix();
    bgRenderer.setSize(bgCanvas.clientWidth, bgCanvas.clientHeight, false);
  });
</script>

{# ── Network graph engine ── #}
<script>
(function() {
  const canvas = document.getElementById('networkGraph');
  const svgEl  = document.getElementById('graphLines');
  const logEl  = document.getElementById('cmdLog');
  if (!canvas || !svgEl) return;

  /* Node definitions: id, label (for log), angle offset for ring placement */
  const nodeIds = ['velocity','paper','folia','purpur','spigot','bukkit'];
  const nodeLabels = {
    velocity: 'Velocity',
    paper: 'Paper',
    folia: 'Folia',
    purpur: 'Purpur',
    spigot: 'Spigot',
    bukkit: 'Bukkit'
  };
  const nodeColors = {
    velocity: '#60a5fa',
    paper: '#6ee7b7',
    folia: '#fbbf24',
    purpur: '#fb7185',
    spigot: '#22d3ee',
    bukkit: '#6ee7b7'
  };

  /* Scenarios: commands that fly between servers */
  const scenarios = [
    { from: 'paper',    to: ['velocity'],                          cmd: '/lobby' },
    { from: 'velocity', to: ['paper','folia','purpur','spigot','bukkit'], cmd: '/alert' },
    { from: 'folia',    to: ['paper'],                             cmd: '/tp' },
    { from: 'paper',    to: ['folia','spigot'],                    cmd: '/sync-inv' },
    { from: 'spigot',   to: ['velocity'],                          cmd: '/send' },
    { from: 'velocity', to: ['purpur'],                            cmd: '/hub-reload' },
    { from: 'purpur',   to: ['paper','folia','spigot','bukkit'],   cmd: '/broadcast' },
    { from: 'bukkit',   to: ['velocity'],                          cmd: '/report' },
    { from: 'velocity', to: ['bukkit','paper'],                    cmd: '/whitelist' },
    { from: 'folia',    to: ['purpur','spigot'],                   cmd: '/transfer' },
  ];

  const hubCx = 50; // percent
  const hubCy = 50;

  /* Place nodes in a ring around the hub */
  function layoutNodes() {
    const count = nodeIds.length;
    const rx = 38; // horizontal radius %
    const ry = 38; // vertical radius %

    nodeIds.forEach((id, i) => {
      const angle = (Math.PI * 2 * i / count) - Math.PI / 2;
      const x = hubCx + rx * Math.cos(angle);
      const y = hubCy + ry * Math.sin(angle);
      const el = document.getElementById('node-' + id);
      if (el) {
        el.style.left = x + '%';
        el.style.top  = y + '%';
      }
    });
  }

  /* Draw SVG lines from hub to each node + idle pulse dots */
  function drawLines() {
    const rect = canvas.getBoundingClientRect();
    const cx = rect.width  * hubCx / 100;
    const cy = rect.height * hubCy / 100;

    let svg = '';
    nodeIds.forEach((id, i) => {
      const el = document.getElementById('node-' + id);
      if (!el) return;
      const nx = parseFloat(el.style.left) / 100 * rect.width;
      const ny = parseFloat(el.style.top)  / 100 * rect.height;

      /* The line */
      svg += '<line class="graph-line" data-node="' + id + '" x1="' + cx + '" y1="' + cy + '" x2="' + nx + '" y2="' + ny + '" />';

      /* Idle dot at midpoint */
      const mx = (cx + nx) / 2;
      const my = (cy + ny) / 2;
      svg += '<circle class="idle-dot" cx="' + mx + '" cy="' + my + '" r="2" />';
    });

    svgEl.innerHTML = svg;
  }

  /* Get pixel center of a node */
  function nodeCenter(id) {
    const el = document.getElementById('node-' + id);
    const rect = canvas.getBoundingClientRect();
    return {
      x: parseFloat(el.style.left) / 100 * rect.width,
      y: parseFloat(el.style.top)  / 100 * rect.height
    };
  }

  /* Animate a packet from src to hub, then hub to each target */
  function firePacket(fromId, toIds, cmd) {
    const fromEl = document.getElementById('node-' + fromId);
    const hub    = { x: canvas.getBoundingClientRect().width * hubCx / 100,
                     y: canvas.getBoundingClientRect().height * hubCy / 100 };
    const src    = nodeCenter(fromId);

    /* Highlight source */
    fromEl.querySelector('.graph-node-inner').classList.add('is-source');

    /* Leg 1: source -> hub */
    createDot(src, hub, nodeColors[fromId], 1000, function() {
      /* Leg 2: hub -> each target (fan out) */
      toIds.forEach(function(tid, idx) {
        const tgt = nodeCenter(tid);
        const tgtEl = document.getElementById('node-' + tid);
        setTimeout(function() {
          tgtEl.querySelector('.graph-node-inner').classList.add('is-target');
          createDot(hub, tgt, nodeColors[tid], 900, function() {
            setTimeout(function() {
              tgtEl.querySelector('.graph-node-inner').classList.remove('is-target');
            }, 600);
          });
        }, idx * 120);
      });
    });

    /* Remove source highlight */
    setTimeout(function() {
      fromEl.querySelector('.graph-node-inner').classList.remove('is-source');
    }, 1200);

    /* Log the command */
    addLog(fromId, toIds, cmd);
  }

  /* Create an animated dot along a straight path */
  function createDot(from, to, color, duration, onDone) {
    const dot = document.createElement('div');
    dot.className = 'graph-packet';
    dot.style.color = color;
    dot.style.background = color;

    /* Use CSS offset-path for the travel */
    const pathD = 'M ' + from.x + ' ' + from.y + ' L ' + to.x + ' ' + to.y;
    dot.style.offsetPath = 'path("' + pathD + '")';
    dot.style.animationDuration = duration + 'ms';

    canvas.appendChild(dot);
    dot.addEventListener('animationend', function() {
      dot.remove();
      if (onDone) onDone();
    });
  }

  /* Add entry to the command log */
  function addLog(fromId, toIds, cmd) {
    const entry = document.createElement('div');
    entry.className = 'cmd-log-entry';

    const targets = toIds.map(function(t) {
      return '<span class="log-node" style="color:' + nodeColors[t] + '">' + nodeLabels[t] + '</span>';
    }).join('<span class="log-arrow">,</span> ');

    entry.innerHTML =
      '<span class="log-node" style="color:' + nodeColors[fromId] + '">' + nodeLabels[fromId] + '</span>' +
      '<span class="log-arrow">&rarr;</span>' +
      targets +
      '<span class="log-cmd">' + cmd + '</span>';

    logEl.appendChild(entry);

    /* Keep max 4 entries */
    while (logEl.children.length > 4) {
      logEl.removeChild(logEl.firstChild);
    }
  }

  /* Init */
  layoutNodes();
  /* Small delay to let layout settle before drawing lines */
  requestAnimationFrame(function() {
    drawLines();
  });

  /* Redraw on resize */
  let resizeTimer;
  window.addEventListener('resize', function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      drawLines();
    }, 100);
  });

  /* Fire scenarios in a loop */
  let idx = 0;
  function nextScenario() {
    const s = scenarios[idx % scenarios.length];
    firePacket(s.from, s.to, s.cmd);
    idx++;
    /* Stagger timing: single-target commands are faster, multi-target get more time */
    const delay = s.to.length > 2 ? 3800 : 2800;
    setTimeout(nextScenario, delay);
  }
  /* Start after 800ms */
  setTimeout(nextScenario, 800);
})();
</script>
