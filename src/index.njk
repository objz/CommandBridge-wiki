<style>
  .cb-bg {
    filter: blur(1.5px);
    -webkit-filter: blur(1.5px);
  }
  .stat-number {
    font-variant-numeric: tabular-nums;
  }

  /* ── Network graph ── */
  .graph-canvas {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    min-height: 320px;
  }

  .graph-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .graph-node {
    position: absolute;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 2;
  }

  .graph-node-inner {
    padding: 0.45rem 0.65rem;
    border-radius: 0.75rem;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card));
    transition: border-color .3s, box-shadow .3s;
    min-width: 4.5rem;
  }

  .graph-node-inner.is-source {
    border-color: rgba(99, 102, 241, 0.7);
    box-shadow: 0 0 14px rgba(99, 102, 241, 0.2);
  }
  .graph-node-inner.is-target {
    border-color: rgba(16, 185, 129, 0.7);
    box-shadow: 0 0 14px rgba(16, 185, 129, 0.2);
  }

  .graph-node h4 {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.3;
  }
  .graph-node .graph-sub {
    margin: 0.05rem 0 0;
    font-size: 0.6rem;
    line-height: 1.3;
    color: hsl(var(--muted-foreground));
  }

  .graph-icon {
    width: 1.3rem;
    height: 1.3rem;
    margin: 0 auto 0.15rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .graph-icon-blue   { background: rgba(59,130,246,0.14); color: #60a5fa; }
  .graph-icon-indigo { background: rgba(99,102,241,0.17); color: #a5b4fc; }
  .graph-icon-green  { background: rgba(16,185,129,0.14); color: #6ee7b7; }
  .graph-icon-amber  { background: rgba(245,158,11,0.14); color: #fbbf24; }
  .graph-icon-rose   { background: rgba(244,63,94,0.14);  color: #fb7185; }
  .graph-icon-cyan   { background: rgba(6,182,212,0.14);  color: #22d3ee; }

  /* Hub center */
  .graph-hub {
    border-color: rgba(99, 102, 241, 0.45);
    box-shadow: 0 0 28px rgba(99, 102, 241, 0.08);
    min-width: 6rem;
  }

  /* Lines */
  .graph-line {
    stroke: hsl(var(--border));
    stroke-width: 1.5;
    fill: none;
  }

  /* Animated packet */
  @keyframes packet-travel {
    0%   { offset-distance: 0%;   opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { offset-distance: 100%; opacity: 0; }
  }

  .graph-packet {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    position: absolute;
    opacity: 0;
    z-index: 1;
    offset-rotate: 0deg;
    animation: packet-travel 1.2s ease-in-out forwards;
    filter: blur(0.5px);
    box-shadow: 0 0 6px currentColor;
  }

  /* Idle pulse dots on lines */
  @keyframes idle-pulse {
    0%, 100% { opacity: .15; r: 2; }
    50%      { opacity: .5;  r: 2.5; }
  }
  .idle-dot {
    fill: #7dd3fc;
    animation: idle-pulse 2.4s ease-in-out infinite;
  }
  .idle-dot:nth-child(2n)  { animation-delay: .6s;  }
  .idle-dot:nth-child(3n)  { animation-delay: 1.2s; }
  .idle-dot:nth-child(5n)  { animation-delay: 1.8s; }

  /* Command log */
  @keyframes log-in {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .cmd-log-entry {
    animation: log-in .3s ease-out forwards;
    font-size: 0.68rem;
    line-height: 1.4;
    padding: 0.15rem 0;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    opacity: 0;
  }
  .cmd-log-entry .log-arrow {
    color: hsl(var(--muted-foreground));
    font-size: 0.6rem;
  }
  .cmd-log-entry .log-node { font-weight: 600; }
  .cmd-log-entry .log-cmd  { color: hsl(var(--muted-foreground)); font-family: ui-monospace, monospace; }

  @media (max-width: 640px) {
    .hero-graph-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      margin: 0 -1rem;
      padding: 0 1rem;
    }
    .hero-graph-inner {
      min-width: 520px;
    }
    .graph-canvas {
      min-height: 280px;
    }
  }
</style>
