<!-- Cookie Consent Banner -->
<div
  x-data="{
    visible: false,
    init() {
      if (!localStorage.getItem('cookie-consent')) {
        this.visible = true;
      }
    },
    accept() {
      localStorage.setItem('cookie-consent', 'accepted');
      this.visible = false;
      // Load Clarity now that consent was given
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src='https://www.clarity.ms/tag/'+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, 'clarity', 'script', 'vp0irfakz8');
    },
    decline() {
      localStorage.setItem('cookie-consent', 'declined');
      this.visible = false;
    }
  }"
  x-show="visible"
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="translate-y-full opacity-0"
  x-transition:enter-end="translate-y-0 opacity-100"
  x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="translate-y-0 opacity-100"
  x-transition:leave-end="translate-y-full opacity-0"
  x-cloak
  class="cookie-banner fixed bottom-0 inset-x-0 z-50 p-4 sm:p-6"
  role="dialog"
  aria-label="Cookie consent"
>
  <div class="mx-auto max-w-screen-md rounded-xl border border-border bg-card/95 backdrop-blur-md shadow-lg p-4 sm:p-5">
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <div class="flex-1 text-sm text-muted-foreground leading-relaxed">
        <p>
          This site uses cookies and
          <a href="https://clarity.microsoft.com/" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 text-foreground hover:text-primary transition-colors">Clarity</a>
          analytics to improve your browsing experience and understand how the site is used. No personal data is collected.
        </p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <button
          @click="decline()"
          class="button-outline text-xs h-8 px-3"
        >
          Decline
        </button>
        <button
          @click="accept()"
          class="button text-xs h-8 px-3"
        >
          Accept
        </button>
      </div>
    </div>
  </div>
</div>
