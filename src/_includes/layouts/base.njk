<!DOCTYPE html>
<html
  lang="en"
  x-data="{
    darkMode: document.documentElement.classList.contains('dark')
  }"
  x-init="$watch('darkMode', val => { document.documentElement.classList.add('theme-transition'); try { localStorage.setItem('dark', val); } catch (e) {} setTimeout(() => document.documentElement.classList.remove('theme-transition'), 420); })"
  x-bind:class="{ 'dark': darkMode }">
<head>
  <meta charset="UTF-8"/>
  <title>{{ site.title + ": " + title if page.url === "/" else title + " - " + site.title }}</title>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <meta name="description" content="{{ description or site.description }}"/>
  <meta name="keywords" content="{{ keywords or site.keywords }}"/>
  <meta name="author" content="{{ site.author }}"/>
  <meta name="robots" content="index, follow"/>
  <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)"/>
  <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)"/>
  <link rel="canonical" href="{{ site.url + page.url }}"/>
  <script>
    (function () {
      try {
        var stored = localStorage.getItem("dark");
        var isDark = stored ? stored === "true" : true;
        document.documentElement.classList.toggle("dark", isDark);

        var onDocsPage = window.location.pathname.startsWith("/docs");
        if (onDocsPage) {
          var wide = localStorage.getItem("wideLayout") === "true";
          document.documentElement.classList.toggle("docs-wide", wide);
        }
      } catch (e) {
        document.documentElement.classList.add("dark");
      }
    })();
  </script>
  <style>
    html { background: #ffffff; color: #0a0a0a; }
    html.dark { background: #0a0a0a; color: #f4f4f5; }
    html.theme-transition *,
    html.theme-transition *::before,
    html.theme-transition *::after {
      transition: background-color 360ms ease, color 300ms ease, border-color 360ms ease, box-shadow 360ms ease, fill 300ms ease, stroke 300ms ease !important;
    }
    html.docs-wide .docs-shell { max-width: calc(100vw - 2rem) !important; }
    @media (min-width: 768px) {
      body.docs-body { height: 100vh; overflow: hidden; }
    }
    @media (min-width: 1024px) {
      html.docs-wide .docs-shell { max-width: calc(100vw - 4rem) !important; }
    }
  </style>
  <link rel="stylesheet" type="text/css" href="/styles.css?build={% now %}"/>
  <link rel="icon" type="image/x-icon" href="{{ site.url }}/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="{{ site.url }}/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="{{ site.url }}/favicon-16x16.png">
  <link rel="apple-touch-icon" type="image/png" sizes="180x180" href="{{ site.url }}/apple-touch-icon.png">
  <link rel="icon" type="image/svg+xml" href="{{ site.url }}/favicon.svg">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="sitemap" type="application/xml" href="/sitemap.xml">
  {# Open Graph #}
  <meta property="og:type" content="{{ type or 'website' }}"/>
  <meta property="og:site_name" content="{{ site.title }}"/>
  <meta property="og:locale" content="{{ site.locale }}"/>
  <meta property="og:title" content="{{ site.title + ": " + title if page.url === "/" else title + " - " + site.title }}"/>
  <meta property="og:description" content="{{ description or site.description }}"/>
  <meta property="og:url" content="{{ site.url + page.url }}"/>
  <meta property="og:image" content="{{ site.url }}{{ site.cover }}"/>
  <meta property="og:image:width" content="1920"/>
  <meta property="og:image:height" content="960"/>
  <meta property="og:image:type" content="image/png"/>
  {# Twitter / X Card #}
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:url" content="{{ site.url + page.url }}"/>
  <meta name="twitter:title" content="{{ site.title + ": " + title if page.url === "/" else title + " - " + site.title }}"/>
  <meta name="twitter:description" content="{{ description or site.description }}"/>
  <meta name="twitter:image" content="{{ site.url }}{{ site.cover }}"/>
  {# JSON-LD Structured Data #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "WebSite",
        "name": "{{ site.title }}",
        "url": "{{ site.url }}",
        "description": "{{ site.description }}",
        "author": {
          "@type": "Person",
          "name": "{{ site.author }}"
        }
      },
      {
        "@type": "SoftwareApplication",
        "name": "{{ site.title }}",
        "url": "{{ site.url }}",
        "description": "{{ site.description }}",
        "applicationCategory": "GameApplication",
        "operatingSystem": "Java",
        "author": {
          "@type": "Person",
          "name": "{{ site.author }}"
        },
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        }
      }{% if type == "article" %},
      {
        "@type": "TechArticle",
        "headline": "{{ title }}",
        "url": "{{ site.url + page.url }}",
        "description": "{{ description or site.description }}",
        "author": {
          "@type": "Person",
          "name": "{{ site.author }}"
        },
        "publisher": {
          "@type": "Person",
          "name": "{{ site.author }}"
        },
        "isPartOf": {
          "@type": "WebSite",
          "name": "{{ site.title }}",
          "url": "{{ site.url }}"
        }
      }{% endif %}
    ]
  }
  </script>
  <script src="/js/alpine.js" defer></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-background antialiased font-inter flex flex-col min-h-screen {{ 'docs-body' if '/docs' in page.url }}">
  {% include "partials/header.njk" %}

  <main class="flex-1 {{ 'docs-main' if '/docs' in page.url }}">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}
</body>

</html>
